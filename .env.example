# Ministry Platform API credentials
# These are configured in the n8n UI, not as environment variables.
# This file documents the values you'll need:

# Your Ministry Platform URL (the /ministryplatformapi path is added automatically)
# Example: https://churchname.ministryplatform.com
MP_PLATFORM_URL=

# OAuth2 client credentials (from MP Admin > API Clients)
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# OAuth2 scope (default shown below — usually doesn't need to change)
MP_SCOPE=http://www.thinkministry.com/dataplatform/scopes/all
