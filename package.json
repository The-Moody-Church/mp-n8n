{
	"name": "n8n-nodes-ministry-platform",
	"version": "0.1.1-beta.1",
	"description": "n8n community node for Ministry Platform — table CRUD, stored procedures, and communications via the MP REST API",
	"license": "MIT",
	"homepage": "https://github.com/The-Moody-Church/mp-n8n",
	"keywords": [
		"n8n-community-node-package",
		"ministry-platform",
		"church-management"
	],
	"author": {
		"name": "The Moody Church",
		"url": "https://github.com/The-Moody-Church"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/The-Moody-Church/mp-n8n.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/MinistryPlatformApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/MinistryPlatform/MinistryPlatform.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
